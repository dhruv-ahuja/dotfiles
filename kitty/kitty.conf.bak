# ~/.config/kitty/kitty.conf
# --------------------------------------------------
# Core behavior
# --------------------------------------------------

# Shell integration (with no-cursor feature like Ghostty)
shell_integration enabled no-cursor

# Clipboard behavior (allow write, ask before read)
clipboard_control write-clipboard write-primary read-clipboard-ask read-primary-ask

# --------------------------------------------------
# Cursor
# --------------------------------------------------

cursor #18E0E0
cursor_shape block
cursor_blink_interval 0

# --------------------------------------------------
# Fonts
# --------------------------------------------------

# font_family Iosevka
font_size 12.5

# Disable ligatures (Ghostty: font-feature=-liga)
disable_ligatures always

# Slight font thickening (macOS rendering tweak)
macos_thicken_font 0.6

# Better line spacing (Ghostty: adjust-cell-height = 10%)
modify_font cell_height 110%

# --------------------------------------------------
# Window sizing & layout
# --------------------------------------------------

# Use fixed cell-based size (like Ghostty)
remember_window_size no
initial_window_width 155c
initial_window_height 40c

# Padding (applies to all sides)
window_padding_width 10

# --------------------------------------------------
# Theme
# --------------------------------------------------

# Recommended: use `kitten themes` to apply Sonokai
# This line is optional if you already applied a theme
# include ./themes/Sonokai.conf

# --------------------------------------------------
# macOS-specific quality-of-life (worth keeping)
# --------------------------------------------------

# Use Cmd+C / Cmd+V like normal mac apps
map cmd+c copy_to_clipboard
map cmd+v paste_from_clipboard

# Better scrolling (optional but useful)
scrollback_lines 10000

# --------------------------------------------------
# Notes / Non-portable Ghostty options
# --------------------------------------------------

# Ghostty had:
# window-title-font-family="MonoLisa Variable"
# → Not supported in kitty

# If you want similar visual polish:
# macos_titlebar_color background
